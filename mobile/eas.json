{
  "cli": {
    "projectId": "coparent-connect",
    "appName": "CoParent Connect",
    "version": "1.1.0"
  },
  "build": {
    "developmentClient": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "development": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "distribution": "app-store",
      "ios": {
        "autoIncrement": true
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "YOUR_APPLE_TEAM_ID",
        "ascAppId": "YOUR_APP_SPECIFIC_PASSWORD",
        "appleIdPassword": "YOUR_APPLE_ID_PASSWORD"
      }
    }
  }
}
