{
  "expo": {
    "name": "CoParent Connect",
    "slug": "coparent-connect",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "coparent",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0d9488",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.coparent.connect"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d9488"
      },
      "package": "com.coparent.connect"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ]
  }
}
