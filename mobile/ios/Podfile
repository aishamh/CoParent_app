require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

platform :ios, '15.1'

prepare_react_native_project!

target 'CoParentConnect' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => true,
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => true,
  )

  # Generate Hermes dSYM for archive uploads (fixes TestFlight warning)
  script_phase :name => 'Generate Hermes dSYM',
    :script => <<~SCRIPT,
      if [ "${ACTION}" = "install" ] || [ -n "${ARCHIVE_PATH}" ]; then
        HERMES_FRAMEWORK="${BUILT_PRODUCTS_DIR}/${FRAMEWORKS_FOLDER_PATH}/hermesvm.framework/hermesvm"
        DSYM_OUTPUT="${DWARF_DSYM_FOLDER_PATH}/hermesvm.framework.dSYM"
        if [ -f "${HERMES_FRAMEWORK}" ] && [ ! -d "${DSYM_OUTPUT}" ]; then
          echo "Generating dSYM for hermesvm.framework..."
          dsymutil "${HERMES_FRAMEWORK}" -o "${DSYM_OUTPUT}" 2>/dev/null || true
          echo "hermesvm dSYM generated at: ${DSYM_OUTPUT}"
        fi
      fi
    SCRIPT
    :execution_position => :after_compile

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |build_config|
        build_config.build_settings['SWIFT_VERSION'] = '5.0'
        build_config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf-with-dsym'
      end
    end
  end
end
